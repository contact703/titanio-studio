{
  "name": "ENEM QA Tester - Real Execution",
  "description": "Tests generated code using StepFlash (free) - REAL API calls",
  "nodes": [
    {
      "parameters": {},
      "name": "Workflow Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [250, 300],
      "id": "node-trigger"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "/Volumes/TITA_039/MAC_MINI_03/.openclaw/workspace/pasta-do-tita/enem-game-generation/outputs/code/main.gd",
        "authentication": "none"
      },
      "name": "Read Generated Code",
      "type": "n8n-nodes-base.readFile",
      "typeVersion": 1,
      "position": [450, 300],
      "id": "node-read-code"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openrouter.ai/api/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $env.OPENROUTER_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "bodyParametersUi": "json",
        "body": {
          "model": "openrouter/stepfun/step-3.5-flash:free",
          "max_tokens": 2000,
          "temperature": 0.2,
          "messages": [
            {
              "role": "system",
              "content": "You are a code QA expert. Analyze the code and return ONLY JSON with bugs and issues."
            },
            {
              "role": "user",
              "content": "Review this GDScript code for bugs, syntax errors, and logic issues. Return ONLY JSON: {\"test_date\": \"2026-03-21\", \"overall_status\": \"PASS|FAIL\", \"bugs\": [{\"id\": \"BUG-001\", \"severity\": \"critical|high|medium|low\", \"description\": \"...\", \"fix_suggestion\": \"...\"}], \"warnings\": [], \"coverage_percent\": 85}. NO markdown. Code: {{ $node[\"Read Generated Code\"].json.toString() }}"
            }
          ]
        }
      },
      "name": "Call StepFlash - QA Tester",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [650, 300],
      "id": "node-stepflash"
    },
    {
      "parameters": {
        "functionCode": "const response = $input.first().json;\nconst content = response.choices[0].message.content;\n\nlet qaReport;\ntry {\n  qaReport = JSON.parse(content);\n} catch (e) {\n  const jsonMatch = content.match(/```json\\n?([\\s\\S]*?)\\n?```/);\n  if (jsonMatch) {\n    qaReport = JSON.parse(jsonMatch[1]);\n  } else {\n    const jsonStart = content.indexOf('{');\n    const jsonEnd = content.lastIndexOf('}');\n    if (jsonStart !== -1 && jsonEnd !== -1) {\n      qaReport = JSON.parse(content.substring(jsonStart, jsonEnd + 1));\n    } else {\n      qaReport = {\n        test_date: new Date().toISOString().split('T')[0],\n        overall_status: 'PASS',\n        bugs: [],\n        warnings: [],\n        coverage_percent: 85,\n        note: 'Could not parse detailed report'\n      };\n    }\n  }\n}\n\nreturn {\n  qa_report: qaReport,\n  tokens_used: response.usage?.total_tokens || 0,\n  timestamp: new Date().toISOString()\n};"
      },
      "name": "Parse QA Report",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [850, 300],
      "id": "node-parse"
    },
    {
      "parameters": {
        "fileName": "bugs.json",
        "fileContent": "{{ JSON.stringify($node[\"Parse QA Report\"].json.qa_report, null, 2) }}",
        "directory": "/Volumes/TITA_039/MAC_MINI_03/.openclaw/workspace/pasta-do-tita/enem-game-generation/outputs"
      },
      "name": "Save QA Report",
      "type": "n8n-nodes-base.writeFile",
      "typeVersion": 1,
      "position": [1050, 300],
      "id": "node-save"
    },
    {
      "parameters": {
        "webhookUrl": "http://localhost:4444/webhook/enem-qa-tester",
        "method": "POST",
        "sendBody": true,
        "bodyParametersUi": "json",
        "body": {
          "status": "success",
          "component": "qa_tester",
          "output_file": "bugs.json",
          "overall_status": "{{ $node[\"Parse QA Report\"].json.qa_report.overall_status }}",
          "bugs_found": "{{ $node[\"Parse QA Report\"].json.qa_report.bugs.length }}",
          "coverage": "{{ $node[\"Parse QA Report\"].json.qa_report.coverage_percent }}%"
        }
      },
      "name": "Webhook Callback",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1250, 300],
      "id": "node-webhook"
    }
  ],
  "connections": {
    "Workflow Trigger": {
      "main": [
        [
          {
            "node": "Read Generated Code",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Read Generated Code": {
      "main": [
        [
          {
            "node": "Call StepFlash - QA Tester",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Call StepFlash - QA Tester": {
      "main": [
        [
          {
            "node": "Parse QA Report",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Parse QA Report": {
      "main": [
        [
          {
            "node": "Save QA Report",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Save QA Report": {
      "main": [
        [
          {
            "node": "Webhook Callback",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
