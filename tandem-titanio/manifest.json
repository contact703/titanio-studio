{
  "manifest_version": 3,
  "name": "Tandem — Titanio AI Browser",
  "version": "1.0.0",
  "description": "Integra a Tita (OpenClaw) diretamente no seu browser",
  "permissions": ["activeTab", "storage", "scripting", "sidePanel"],
  "host_permissions": ["http://localhost:18789/*"],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }]
}
