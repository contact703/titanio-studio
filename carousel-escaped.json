"<style>\n.locations-carousel-wrapper {\n  padding: 60px 20px;\n  background-color: #f8f9fa;\n}\n\n.locations-header {\n  text-align: center;\n  margin-bottom: 50px;\n}\n\n.locations-header h2 {\n  font-size: 32px;\n  font-weight: 700;\n  color: #003d7a;\n  margin-bottom: 20px;\n}\n\n.locations-header p {\n  font-size: 16px;\n  color: #666;\n  max-width: 700px;\n  margin: 0 auto;\n  line-height: 1.6;\n}\n\n.carousel-container {\n  position: relative;\n  max-width: 1200px;\n  margin: 0 auto;\n}\n\n.carousel-grid {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  gap: 30px;\n  margin-bottom: 40px;\n}\n\n.location-card {\n  position: relative;\n  border-radius: 12px;\n  overflow: hidden;\n  cursor: pointer;\n  transition: transform 0.3s ease, box-shadow 0.3s ease;\n  height: 250px;\n  background-size: cover;\n  background-position: center;\n  display: flex;\n  align-items: flex-end;\n  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);\n  text-decoration: none;\n}\n\n.location-card:hover {\n  transform: translateY(-5px);\n  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);\n}\n\n.location-card-overlay {\n  position: absolute;\n  top: 0;\n  left: 0;\n  right: 0;\n  bottom: 0;\n  background: linear-gradient(to top, rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.2));\n  display: flex;\n  flex-direction: column;\n  justify-content: flex-end;\n  padding: 20px;\n  color: white;\n}\n\n.location-card-category {\n  font-size: 12px;\n  font-weight: 600;\n  text-transform: uppercase;\n  letter-spacing: 1px;\n  color: rgba(255, 255, 255, 0.9);\n  margin-bottom: 8px;\n}\n\n.location-card-name {\n  font-size: 18px;\n  font-weight: 700;\n  color: white;\n}\n\n.carousel-nav {\n  display: flex;\n  justify-content: center;\n  gap: 20px;\n  align-items: center;\n}\n\n.carousel-arrow {\n  width: 50px;\n  height: 50px;\n  border-radius: 50%;\n  background-color: #003d7a;\n  border: none;\n  color: white;\n  font-size: 24px;\n  cursor: pointer;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  transition: background-color 0.3s ease, transform 0.2s ease;\n}\n\n.carousel-arrow:hover {\n  background-color: #002a5a;\n  transform: scale(1.05);\n}\n\n.carousel-arrow:active {\n  transform: scale(0.95);\n}\n\n.carousel-dots {\n  display: flex;\n  justify-content: center;\n  gap: 10px;\n  margin-top: 30px;\n}\n\n.carousel-dot {\n  width: 12px;\n  height: 12px;\n  border-radius: 50%;\n  background-color: #ddd;\n  border: none;\n  cursor: pointer;\n  transition: background-color 0.3s ease;\n}\n\n.carousel-dot.active {\n  background-color: #003d7a;\n}\n\n.submit-location-btn {\n  display: block;\n  margin: 40px auto 0;\n  padding: 15px 40px;\n  background-color: #d4a574;\n  color: white;\n  border: none;\n  border-radius: 5px;\n  font-size: 14px;\n  font-weight: 600;\n  text-transform: uppercase;\n  cursor: pointer;\n  transition: background-color 0.3s ease;\n  text-decoration: none;\n}\n\n.submit-location-btn:hover {\n  background-color: #c49464;\n}\n\n@media (max-width: 1024px) {\n  .carousel-grid {\n    grid-template-columns: repeat(2, 1fr);\n    gap: 20px;\n  }\n}\n\n@media (max-width: 768px) {\n  .carousel-grid {\n    grid-template-columns: 1fr;\n    gap: 20px;\n  }\n\n  .locations-header h2 {\n    font-size: 24px;\n  }\n\n  .location-card {\n    height: 200px;\n  }\n}\n</style>\n\n<div class=\"locations-carousel-wrapper\">\n  <div class=\"locations-header\">\n    <h2>Explore as Loca\u00e7\u00f5es \u00danicas de Maric\u00e1</h2>\n    <p>Com uma incr\u00edvel variedade de paisagens \u2014 desde praias costeiras at\u00e9 fazendas rurais, cen\u00e1rios urbanos e s\u00edtios hist\u00f3ricos \u2014 Maric\u00e1 oferece aos cineastas um mundo de possibilidades dentro de uma \u00fanica regi\u00e3o.</p>\n  </div>\n\n  <div class=\"carousel-container\">\n    <div class=\"carousel-grid\" id=\"carouselGrid\"></div>\n\n    <div class=\"carousel-nav\">\n      <button class=\"carousel-arrow prev\" onclick=\"previousSlide()\">\u2039</button>\n      <div class=\"carousel-dots\" id=\"carouselDots\"></div>\n      <button class=\"carousel-arrow next\" onclick=\"nextSlide()\">\u203a</button>\n    </div>\n  </div>\n\n  <a href=\"/cadastre-sua-locacao/\" class=\"submit-location-btn\">Cadastre Sua Loca\u00e7\u00e3o</a>\n</div>\n\n<script>\nconst locations = [\n  { name: \"Praias de Itaipua\u00e7u\", category: \"Praias\", image: \"https://maricafilmcommission.com/wp-content/uploads/2025/04/new_events-scaled.jpg\", url: \"/praias-de-itaipuacu/\" },\n  { name: \"Praia de Ponta Negra\", category: \"Praias\", image: \"https://maricafilmcommission.com/wp-content/uploads/2025/04/new_events-scaled.jpg\", url: \"/praia-de-ponta-negra/\" },\n  { name: \"Praia do Recanto\", category: \"Praias\", image: \"https://maricafilmcommission.com/wp-content/uploads/2025/04/new_events-scaled.jpg\", url: \"/farol-de-ponta-negra/\" },\n  { name: \"Extens\u00e3o da Restinga\", category: \"Natureza\", image: \"https://maricafilmcommission.com/wp-content/uploads/2025/04/new_events-scaled.jpg\", url: \"/extensao-da-restinga/\" },\n  { name: \"Lagoa de Ara\u00e7atiba\", category: \"Lagos\", image: \"https://maricafilmcommission.com/wp-content/uploads/2025/04/new_events-scaled.jpg\", url: \"/lagoa-de-aracatiba-2/\" },\n  { name: \"Gruta da Sacristia\", category: \"Natureza\", image: \"https://maricafilmcommission.com/wp-content/uploads/2025/04/new_events-scaled.jpg\", url: \"/gruta-da-sacristia/\" },\n  { name: \"Pedra do Macaco\", category: \"Natureza\", image: \"https://maricafilmcommission.com/wp-content/uploads/2025/04/new_events-scaled.jpg\", url: \"/pedra-do-macaco/\" },\n  { name: \"Farol de Ponta Negra\", category: \"Monumentos\", image: \"https://maricafilmcommission.com/wp-content/uploads/2025/04/new_events-scaled.jpg\", url: \"/ponta-negra-lighthouse/\" },\n  { name: \"Igreja Matriz N. Sra. do Amparo\", category: \"Monumentos\", image: \"https://maricafilmcommission.com/wp-content/uploads/2025/04/new_events-scaled.jpg\", url: \"/igreja-matriz-de-nossa-senhora-do-amparo-2/\" },\n  { name: \"Cinema Henfil\", category: \"Cultura\", image: \"https://maricafilmcommission.com/wp-content/uploads/2025/04/new_events-scaled.jpg\", url: \"/cinema-henfil/\" },\n  { name: \"Parque Linear Flamengo\", category: \"Parques\", image: \"https://maricafilmcommission.com/wp-content/uploads/2025/04/new_events-scaled.jpg\", url: \"/parque-linear-do-bairro-flamengo/\" },\n  { name: \"Est\u00e1dio Jo\u00e3o Saldanha\", category: \"Esportes\", image: \"https://maricafilmcommission.com/wp-content/uploads/2025/04/new_events-scaled.jpg\", url: \"/estadio-de-futebol-joao-saldanha/\" },\n  { name: \"Deck do P\u00f4r do Sol\", category: \"Lazer\", image: \"https://maricafilmcommission.com/wp-content/uploads/2025/04/new_events-scaled.jpg\", url: \"/deck-do-por-do-sol/\" },\n  { name: \"Pedra do Elefante\", category: \"Natureza\", image: \"https://maricafilmcommission.com/wp-content/uploads/2025/04/new_events-scaled.jpg\", url: \"/pedra-do-elefante-2/\" },\n  { name: \"Orla de Itapeba\", category: \"Parques\", image: \"https://maricafilmcommission.com/wp-content/uploads/2025/04/new_events-scaled.jpg\", url: \"/orla-de-itapeba/\" },\n  { name: \"Casa de Cultura\", category: \"Cultura\", image: \"https://maricafilmcommission.com/wp-content/uploads/2025/04/new_events-scaled.jpg\", url: \"/casa-de-cultura-pt/\" },\n  { name: \"Pra\u00e7a Orlando de Barros Pimentel\", category: \"Urbano\", image: \"https://maricafilmcommission.com/wp-content/uploads/2025/04/new_events-scaled.jpg\", url: \"/praca-orlando-de-barros-pimentel/\" },\n  { name: \"Fazenda Itaocaia\", category: \"Hist\u00f3rico\", image: \"https://maricafilmcommission.com/wp-content/uploads/2025/04/new_events-scaled.jpg\", url: \"/fazenda-itaocaia-pt/\" },\n  { name: \"Fazenda Joaquim Pi\u00f1ero\", category: \"Hist\u00f3rico\", image: \"https://maricafilmcommission.com/wp-content/uploads/2025/04/new_events-scaled.jpg\", url: \"/fazenda-joaquim-pinero-pt/\" },\n  { name: \"Aldeia Mata Verde Bonita\", category: \"Cultural\", image: \"https://maricafilmcommission.com/wp-content/uploads/2025/04/new_events-scaled.jpg\", url: \"/aldeia-mata-verde-bonita-pt/\" },\n  { name: \"Hospital Dr. Che Guevara\", category: \"Urbano\", image: \"https://maricafilmcommission.com/wp-content/uploads/2025/04/new_events-scaled.jpg\", url: \"/hospital-municipal-che-guevara-pt/\" }\n];\n\nlet currentSlide = 0;\nconst cardsPerPage = 3;\n\nfunction renderCarousel() {\n  const grid = document.getElementById('carouselGrid');\n  const dotsContainer = document.getElementById('carouselDots');\n  if (!grid) return;\n\n  grid.innerHTML = '';\n  dotsContainer.innerHTML = '';\n\n  const totalPages = Math.ceil(locations.length / cardsPerPage);\n  const startIndex = currentSlide * cardsPerPage;\n  const endIndex = Math.min(startIndex + cardsPerPage, locations.length);\n\n  for (let i = startIndex; i < endIndex; i++) {\n    const loc = locations[i];\n    const card = document.createElement('a');\n    card.href = loc.url;\n    card.className = 'location-card';\n    card.style.backgroundImage = \"url('\" + loc.image + \"')\";\n    card.innerHTML = '<div class=\"location-card-overlay\"><div class=\"location-card-category\">' + loc.category + '</div><div class=\"location-card-name\">' + loc.name + '</div></div>';\n    grid.appendChild(card);\n  }\n\n  for (let i = 0; i < totalPages; i++) {\n    const dot = document.createElement('button');\n    dot.className = 'carousel-dot' + (i === currentSlide ? ' active' : '');\n    dot.onclick = () => { currentSlide = i; renderCarousel(); };\n    dotsContainer.appendChild(dot);\n  }\n}\n\nfunction nextSlide() {\n  const totalPages = Math.ceil(locations.length / cardsPerPage);\n  currentSlide = (currentSlide + 1) % totalPages;\n  renderCarousel();\n}\n\nfunction previousSlide() {\n  const totalPages = Math.ceil(locations.length / cardsPerPage);\n  currentSlide = (currentSlide - 1 + totalPages) % totalPages;\n  renderCarousel();\n}\n\ndocument.addEventListener('DOMContentLoaded', function() {\n  renderCarousel();\n});\n</script>\n"